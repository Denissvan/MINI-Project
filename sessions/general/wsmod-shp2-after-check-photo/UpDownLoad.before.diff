+        private void CacheAfterCloseTargets()
+        {
+            if (FeedBackWs == null || FeedBackWs.Count == 0)
+            {
+                return;
+            }
+
+            foreach (WS.MdDat md in FeedBackWs)
+            {
+                AfterCloseTarget target = afterCloseTargets.FirstOrDefault(t => t.Md.Num == md.Num);
